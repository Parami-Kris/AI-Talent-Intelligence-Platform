GOOGLE_API_KEY=your_google_api_key
GENAI_MODEL=gemini-3.1-flash-lite

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ai_resume_screening

ALLOWED_ORIGIN=http://localhost:5173

# Job search (job seeker "search real JDs" feature) - both optional, missing
# keys just make that source unavailable instead of erroring.
# SerpApi (Google Jobs) is primary: free tier 250 searches/month, no card
# required. https://serpapi.com/google-jobs-api
SERP_API_KEY=your_serpapi_key
# Bright Data Web Unlocker is the fallback once SerpApi's monthly quota runs
# out: 5,000/month free. Requires creating a "Web Unlocker API" zone in the
# Bright Data dashboard first (BRIGHT_DATA_SERP_ZONE = that zone's name) -
# scrapes Google's Jobs vertical directly, more fragile long-term than SerpApi
# since it's tied to Google's current page markup rather than a maintained API.
BRIGHT_DATA_API_KEY=your_bright_data_api_key
BRIGHT_DATA_SERP_ZONE=your_zone_name
# Dropped Adzuna/Jooble/Remotive - Adzuna/Jooble cap descriptions at ~300-500
# chars with no API-level fix (confirmed against their docs); Remotive is
# remote-jobs-only and was dropped by product decision for broader coverage.

# Related-title query expansion for job search (e.g. "ML Engineer" search also
# fires related searches like "Applied Scientist"). Optional - missing key just
# skips expansion. Uses Groq (not Gemini) so it doesn't compete for Gemini quota.
# Expansions are cached in MySQL (query_expansions table) so repeat searches are free.
GROQ_API_KEY=your_groq_api_key
